# Ọ̀ṣỌ́ Environment Variables

# Required: Anthropic API key for the Claude translator
ANTHROPIC_API_KEY=sk-ant-...

# Sui network (testnet | mainnet | devnet)
NEXT_PUBLIC_SUI_NETWORK=testnet

# Sui package ID (set after deploying contracts)
NEXT_PUBLIC_SUI_PACKAGE_ID=0x0

# Walrus endpoints (defaults to testnet)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
